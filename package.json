{
  "name": "declarative-pdf",
  "version": "1.1.2",
  "description": "A tool for generating PDF documents from declarative HTML templates",
  "keywords": [
    "pdf",
    "html",
    "declarative",
    "template",
    "document",
    "generate",
    "generate-pdf",
    "generate-pdf-from-html"
  ],
  "main": "./dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.wrapper.cjs",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.18"
  },
  "author": "The Productive Company",
  "contributors": [
    "Tibor Rogulja"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/productiveio/declarative-pdf.git"
  },
  "scripts": {
    "build": "pnpm run test && pnpm run build:lib",
    "build:lib": "rm -rf dist && tsup src/index.ts --format cjs,esm --dts --clean && cp shims/index.wrapper.cjs dist/",
    "examples": "node docs/examples/index.js",
    "lint": "eslint .",
    "test": "node ./bin/check-canvas.cjs && jest",
    "test:cov": "node ./bin/check-canvas.cjs && jest --coverage",
    "test:ci": "jest --detectOpenHandles --testPathIgnorePatterns=\"<rootDir>/test/visual.test.ts\""
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "24.7.2",
    "@typescript-eslint/eslint-plugin": "8.46.1",
    "@typescript-eslint/parser": "8.46.1",
    "compare-pdf": "1.1.8",
    "eslint": "9.37.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.4",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "jest-ts-webcompat-resolver": "1.0.1",
    "jsdom": "27.0.0",
    "prettier": "3.6.2",
    "puppeteer": "24.24.1",
    "ts-jest": "29.4.5",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "tsup": "8.5.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "pdf-lib": "1.17.1"
  },
  "packageManager": "pnpm@9.12.2+sha512.22721b3a11f81661ae1ec68ce1a7b879425a1ca5b991c975b074ac220b187ce56c708fe5db69f4c962c989452eee76c82877f4ee80f474cebd61ee13461b6228",
  "pnpm": {
    "overrides": {
      "micromatch@<4.0.8": ">=4.0.8",
      "@babel/helpers@<7.26.10": ">=7.26.10",
      "pdfjs-dist@<=4.1.392": ">=4.2.67",
      "cross-spawn@<6.0.6": ">=6.0.6",
      "tar-fs@>=3.0.0 <3.0.9": ">=3.0.9",
      "brace-expansion@>=1.0.0 <=1.1.11": "1.1.12",
      "brace-expansion@>=2.0.0 <=2.0.1": "2.0.2",
      "basic-ftp@<=5.2.1": "5.2.2",
      "flatted@<=3.4.1": "3.4.2",
      "handlebars@>=4.0.0 <=4.7.8": "4.7.9",
      "rollup@>=4.0.0 <4.59.0": "4.60.1",
      "tar@<7.5.11": "7.5.13",
      "lodash@>=4.0.0 <=4.17.23": "4.18.1",
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "minimatch@<3.1.4": "3.1.5",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "glob@>=10.2.0 <10.5.0": "10.5.0",
      "js-yaml@<3.14.2": "3.14.2",
      "js-yaml@>=4.0.0 <4.1.1": "4.1.1",
      "ajv@<6.14.0": "6.14.0",
      "diff@>=4.0.0 <4.0.4": "4.0.4"
    }
  }
}
